# Copy to .env.local and fill in real values from Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Google Drive service account (Phase 2)
# From Google Cloud Console → IAM & Admin → Service Accounts → your service account → Keys → Add Key → JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=drive-reader@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON file. Keep the literal \n characters intact.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
